      "boundElements": null,
      "updated": 1770267131108,
      "link": null,
      "locked": false,
      "text": "void consumer()\n {\n        while (true)\n        {\n                wait(full); // wait if buffer is empty\n                wait(mutex); // enter critical section\n\n                remove(); // remove item from buffer\n\n                signal(mutex); // exit critical section\n                signal(empty); // increment empty slots\n\n                consume(); // consume item\n        }\n}",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "void consumer()\n {\n        while (true)\n        {\n                wait(full); // wait if buffer is empty\n                wait(mutex); // enter critical section\n\n                remove(); // remove item from buffer\n\n                signal(mutex); // exit critical section\n                signal(empty); // increment empty slots\n\n                consume(); // consume item\n        }\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
