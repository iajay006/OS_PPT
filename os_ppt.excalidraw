    {
      "id": "wSXmHUGLhzOfuBDK5r7rE",
      "type": "text",
      "x": 637,
      "y": 160,
      "width": 320.399658203125,
      "height": 300,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
