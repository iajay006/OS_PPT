      "seed": 2143949442,
      "version": 43,
      "versionNonce": 1564254622,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1770266872961,
      "link": null,
      "locked": false,
      "text": "void producer()\n{\n        while (true)\n        {\n                produce(); // produce an item\n\n                wait(empty); // wait if buffer is full\n                wait(mutex); // enter critical section\n\n                append(); // add item to buffer\n\n                signal(mutex); // exit critical section\n                signal(full); // increment full slots\n        }\n}",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "void producer()\n{\n        while (true)\n        {\n                produce(); // produce an item\n\n                wait(empty); // wait if buffer is full\n                wait(mutex); // enter critical section\n\n                append(); // add item to buffer\n\n                signal(mutex); // exit critical section\n                signal(full); // increment full slots\n        }\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
